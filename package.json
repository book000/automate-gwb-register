    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.8.3",
    "run-z": "2.1.0",
    "tsx": "4.22.0",
    "typescript": "6.0.3"
  },
